# Unity .gitattributes

# Auto-detect text files and perform LF normalization
* text=auto

# Unity YAML files - treat as text, use LF
*.cs        text eol=lf
*.shader    text eol=lf
*.cginc     text eol=lf
*.hlsl      text eol=lf
*.glsl      text eol=lf

*.unity     text eol=lf merge=unityyamlmerge
*.prefab    text eol=lf merge=unityyamlmerge
*.asset     text eol=lf merge=unityyamlmerge
*.meta      text eol=lf
*.controller text eol=lf
*.anim      text eol=lf
*.mask      text eol=lf
*.mat       text eol=lf
*.physicsMaterial2D text eol=lf
*.guiskin   text eol=lf
*.fontsettings text eol=lf
*.renderTexture text eol=lf
*.spriteatlas text eol=lf
*.overrideController text eol=lf

*.json      text eol=lf
*.xml       text eol=lf
*.txt       text eol=lf
*.md        text eol=lf
*.inputactions text eol=lf
*.wlt       text eol=lf

# Binary files - do not modify
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.tga       binary
*.tif       binary
*.tiff      binary
*.psd       binary
*.pdf       binary
*.zip       binary
*.7z        binary
*.gz        binary
*.mp3       binary
*.wav       binary
*.ogg       binary
*.mp4       binary
*.avi       binary
*.mov       binary
*.fbx       binary
*.obj       binary
*.blend     binary
*.dll       binary
*.so        binary
*.exe       binary
*.unitypackage binary
